rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Properties and Neighborhoods are fully public to read.
    // Writes (create/update/delete) require Firebase Authentication (Admin Dashboard).
    match /properties/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /neighborhoods/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
